# Docker Compose 専用 - docker-compose.yml の変数展開に使用
# ローカル開発（npm run dev）では不要。各サービスの .env を使うこと。

# Auth0 設定（マイクロサービス用 - https:// を含む完全 URL）
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_AUDIENCE=https://api.nexuscrm.com

# Auth0 設定（フロントエンド用 - @auth0/nextjs-auth0 v4）
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_SECRET=change-me-to-at-least-32-random-characters
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
