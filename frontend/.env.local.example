# Auth0
AUTH0_SECRET=change-me-to-at-least-32-random-characters
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=https://api.nexuscrm.com
AUTH0_SCOPE=openid profile email offline_access read:accounts create:accounts update:accounts delete:accounts read:opportunities create:opportunities update:opportunities delete:opportunities read:contacts create:contacts update:contacts delete:contacts read:activities create:activities update:activities delete:activities read:users create:users update:users delete:users

# Microservices（Dockerなしでローカル開発する場合）
ACCOUNT_SERVICE_URL=http://localhost:3001
OPPORTUNITY_SERVICE_URL=http://localhost:3002
CONTACT_SERVICE_URL=http://localhost:3003
ACTIVITY_SERVICE_URL=http://localhost:3004
USER_SERVICE_URL=http://localhost:3005
