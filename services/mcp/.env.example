PORT=3006
MCP_SERVER_URL=http://localhost:3006

# Auth0 (同じテナントを使用)
# フロントエンド/マイクロサービスと同じドメイン (スキームなし)
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN.auth0.com

# MCP サーバーの OAuth audience
AUTH0_AUDIENCE=https://api.nexuscrm.com

# マイクロサービスの OAuth audience
API_AUDIENCE=https://api.nexuscrm.com

# マイクロサービスの URL (デフォルトはローカル開発用)
ACCOUNTS_SERVICE_URL=http://localhost:3001
OPPORTUNITIES_SERVICE_URL=http://localhost:3002
CONTACTS_SERVICE_URL=http://localhost:3003
ACTIVITIES_SERVICE_URL=http://localhost:3004
USERS_SERVICE_URL=http://localhost:3005

# OBO Token Exchange — MCP server の confidential client 認証情報
# Auth0 で Native アプリとして登録し、Organization に割り当てたアプリ
AUTH0_CLIENT_ID=YOUR_MCP_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_MCP_CLIENT_SECRET
